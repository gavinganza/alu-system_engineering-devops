# 1. Install ufw if it is not already present
sudo apt-get update
sudo apt-get install ufw

# 2. Set the default policy to deny all incoming traffic
sudo ufw default deny incoming

# 3. Set the default policy to allow all outgoing traffic
sudo ufw default allow outgoing

# 4. Allow specific TCP ports: 22 (SSH), 80 (HTTP), and 443 (HTTPS)
sudo ufw allow 22/tcp
sudo ufw allow 80/tcp
sudo ufw allow 443/tcp

# 5. Enable the firewall
# Note: You will be prompted to confirm; type 'y'
sudo ufw  --force enable